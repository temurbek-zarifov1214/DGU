<?xml version="1.0" encoding="utf-8"?>
<!-- Glass menu card: top-edge shine line + colored icon square + labels -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/ripple_glass">

    <!-- Top-edge shine (1dp high) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/shine_top" />

    <!-- Card body with padding -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="10dp">

        <!-- Icon container (coloured rounded square) -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:tint="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvLabel1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F0FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvLabel2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F0FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvSublabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="#66FFFFFF"
            android:textSize="9sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>
</LinearLayout>
