<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="180"
                android:startColor="@color/dark_blue_light"
                android:centerColor="@color/dark_blue_primary"
                android:endColor="@color/dark_blue_dark"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:top="80dp"
        android:bottom="0dp"
        android:left="0dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#1A000000"
                android:endColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
