    <path
        android:fillColor="#D0E4FF"
        android:pathData="M54,42 L68,43 L54,49 Z"/>
    <!-- Cylinder head -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M51,49 L57,49 L57,55 L51,55 Z"/>
