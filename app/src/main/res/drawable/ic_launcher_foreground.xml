<?xml version="1.0" encoding="utf-8"?>
<!--
  Pedagogy-themed adaptive icon foreground.
  Safe zone is the inner 66×66dp area (108dp total, 21dp padding each side).
  All coordinates are in the 108×108 viewport.
  Scene: open book (white) + graduation cap (white) above + 3 gold stars
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Background circle (fills safe zone nicely) -->
    <path
        android:fillColor="#1155CC"
        android:pathData="M54,18 a36,36 0 1,0 0.001,0 Z"/>

    <!-- Glow ring around circle -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#40FFFFFF"
        android:strokeWidth="1"
        android:pathData="M54,16 a38,38 0 1,0 0.001,0 Z"/>

    <!-- ── Open Book (centred ~55,65 area) ────────────────────────────────── -->
