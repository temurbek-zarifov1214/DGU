    <path
        android:fillColor="#E8F0FF"
        android:pathData="
            M30,56 L53,53 L53,74 L30,72 Z"/>
    <!-- Right page -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M55,53 L78,56 L78,72 L55,74 Z"/>
    <!-- Spine shadow -->
    <path
        android:fillColor="#3300AAFF"
        android:pathData="M53,53 L55,53 L55,74 L53,74 Z"/>
